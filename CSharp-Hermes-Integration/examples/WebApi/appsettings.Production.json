{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "HermesAgent": "Information"
    }
  },
  "Urls": "http://0.0.0.0:8080",
  "HermesAgent": {
    "BaseUrl": "http://localhost:8642",
    "ApiKey": "hermes...0416",
    "WebhookSecret": "dotnet-webhook-secret",
    "Timeout": 30,
    "MaxRetries": 3,
    "DefaultModel": "hermes-agent",
    "Temperature": 0.7,
    "EnableFileTools": true,
    "EnableTerminalTools": true,
    "EnableWebTools": false,
    "WebhookRoute": "dotnet-webhook",
    "WebhookBaseUrl": "http://localhost:8644",
    "EnableHealthCheck": true,
    "HealthCheckInterval": 60
  },
  "Swagger": {
    "Enabled": false,
    "RoutePrefix": "swagger",
    "DocumentTitle": "Hermes Agent API",
    "DocumentVersion": "v1",
    "IncludeSecurity": true,
    "EnableTryItOut": false,
    "EnableDeepLinking": true
  }
}