{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "HermesAgent": "Information"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:8080;https://localhost:8443",
